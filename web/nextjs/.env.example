# YouTube video ID for hero background (example: abc123XYZ)
NEXT_PUBLIC_HERO_VIDEO_ID=7gWl1-k6QpE

# Optional: comma-separated Instagram post/reel URLs to embed in gallery
# Example: https://www.instagram.com/reel/ABC123/,https://www.instagram.com/p/XYZ789/
NEXT_PUBLIC_INSTAGRAM_POST_URLS=

# Optional: direct Instagram media video URLs (.mp4), comma-separated
NEXT_PUBLIC_INSTAGRAM_VIDEO_LINKS=

# Optional: comma-separated YouTube links/ids to embed in gallery
NEXT_PUBLIC_GALLERY_YOUTUBE_LINKS=

# Admin token used by /admin to persist changes through API
CMS_ADMIN_TOKEN=

# Optional HTTP Basic Auth for /admin access
CMS_ADMIN_USER=
CMS_ADMIN_PASSWORD=

# Optional override for media storage root. Railway volume default in Linux is /storage/media.
# MEDIA_STORAGE_ROOT=/storage/media

# Optional override for CMS JSON storage root. Railway volume default in Linux is /storage/cms.
# CONTENT_STORAGE_ROOT=/storage/cms
